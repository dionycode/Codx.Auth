@model Codx.Auth.ViewModels.Invitations.CreateInvitationViewModel

@{
    ViewData["Title"] = "Send Invitation";
}

<h2>Send Invitation</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TenantId" />
    <input type="hidden" asp-for="CompanyId" />

    <div class="form-group">
        <label asp-for="Email"></label>
        <input class="form-control" asp-for="Email" type="email" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    @if (Model.AvailableRoles.Any())
    {
        <div class="form-group">
            <label asp-for="SelectedRoleIds">Roles</label>
            <div class="border rounded p-3">
                @foreach (var role in Model.AvailableRoles)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="SelectedRoleIds"
                               value="@role.Id"
                               id="role_@role.Id"
                               @(Model.SelectedRoleIds?.Contains(role.Id) == true ? "checked" : "") />
                        <label class="form-check-label" for="role_@role.Id">
                            @role.DisplayName
                            <small class="text-muted">(@role.ScopeType)</small>
                        </label>
                    </div>
                }
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Send Invitation</button>
    <a asp-action="Index" asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.CompanyId"
       class="btn btn-secondary ml-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
