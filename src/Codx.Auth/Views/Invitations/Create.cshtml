@using Codx.Auth.Data.Entities.Enterprise
@model Codx.Auth.ViewModels.Invitations.CreateInvitationViewModel

@{
    ViewData["Title"] = "Send Invitation";
    var tenantRoles = Model.AvailableRoles?.Where(r => r.ScopeType == "Tenant").ToList();
    var companyRoles = Model.AvailableRoles?.Where(r => r.ScopeType == "Company").ToList();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        @if (User.IsInRole("PlatformAdministrator"))
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Tenants")">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId">Tenant Details</a></li>
        }
        else
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
            <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId">Tenant</a></li>
        }
        <li class="breadcrumb-item active" aria-current="page">Send Invitation</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Send Invitation</h5>
            </div>
            <div class="card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TenantId" />
                    <input type="hidden" asp-for="CompanyId" />

                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input class="form-control" asp-for="Email" type="email" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    @if (tenantRoles?.Any() == true)
                    {
                        <div class="form-group">
                            <label class="font-weight-bold">Tenant Roles</label>
                            @foreach (var role in tenantRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedRoleIds" value="@role.Id"
                                           id="role_@role.Id"
                                           @(Model.SelectedRoleIds?.Contains(role.Id) == true ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role.Id">
                                        @role.DisplayName
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    @if (companyRoles?.Any() == true)
                    {
                        <div class="form-group">
                            <label class="font-weight-bold">Company Roles</label>
                            @foreach (var role in companyRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedRoleIds" value="@role.Id"
                                           id="role_@role.Id"
                                           @(Model.SelectedRoleIds?.Contains(role.Id) == true ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role.Id">
                                        @role.DisplayName
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Send Invitation</button>
                        @if (User.IsInRole("PlatformAdministrator"))
                        {
                            <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId"
                               class="btn btn-secondary ml-2">Cancel</a>
                        }
                        else
                        {
                            <a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId"
                               class="btn btn-secondary ml-2">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
