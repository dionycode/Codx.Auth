@using Codx.Auth.Data.Entities.Enterprise
@model List<EnterpriseApplication>

@{
    ViewData["Title"] = "Applications";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Applications</h2>
    <a asp-action="Add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Application</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Display Name</th>
            <th>Self-Registration</th>
            <th>Active</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var app in Model)
        {
            <tr>
                <td><code>@app.Id</code></td>
                <td>@app.DisplayName</td>
                <td>@(app.AllowSelfRegistration ? "Yes" : "No")</td>
                <td>@(app.IsActive ? "Yes" : "No")</td>
                <td><a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-outline-primary">Details</a></td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="5" class="text-center text-muted">No applications registered.</td></tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
