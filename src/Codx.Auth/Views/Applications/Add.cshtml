@model Codx.Auth.ViewModels.Applications.ApplicationAddViewModel

@{
    ViewData["Title"] = "Add Application";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Applications")">Applications</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add Application</li>
    </ol>
</nav>

<h2>Add Application</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Add" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="Id">Application ID</label>
        <input class="form-control" asp-for="Id" placeholder="e.g. my-app" />
        <small class="form-text text-muted">Lowercase letters, numbers and hyphens only. Used as the unique identifier and cannot be changed.</small>
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DisplayName"></label>
        <input class="form-control" asp-for="DisplayName" />
        <span asp-validation-for="DisplayName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea class="form-control" asp-for="Description" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" asp-for="AllowSelfRegistration" />
        <label class="form-check-label" asp-for="AllowSelfRegistration">Allow Self-Registration</label>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary ml-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
