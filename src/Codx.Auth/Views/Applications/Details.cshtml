@model Codx.Auth.ViewModels.Applications.ApplicationDetailsViewModel

@{
    ViewData["Title"] = Model.Application.DisplayName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Applications")">Applications</a></li>
        <li class="breadcrumb-item active" aria-current="page">Application</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <nav>
                    <div class="nav nav-tabs" id="nav-tab" role="tablist">
                        <a class="nav-item nav-link active" id="nav-details-tab" data-toggle="tab" href="#nav-details" role="tab" aria-controls="nav-details" aria-selected="true">Details</a>
                        <a class="nav-item nav-link" id="nav-roles-tab" data-toggle="tab" href="#nav-roles" role="tab" aria-controls="nav-roles" aria-selected="false">Roles</a>
                        <a class="nav-item nav-link" id="nav-clients-tab" data-toggle="tab" href="#nav-clients" role="tab" aria-controls="nav-clients" aria-selected="false">Linked Clients</a>
                        <a class="nav-item nav-link" id="nav-assignments-tab" data-toggle="tab" href="#nav-assignments" role="tab" aria-controls="nav-assignments" aria-selected="false">User Assignments</a>
                    </div>
                </nav>
            </div>
            <div class="card-body">
                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane fade show active" id="nav-details" role="tabpanel" aria-labelledby="nav-details-tab">
                        <br />
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="form-group">
                                    <label>ID</label>
                                    <input value="@Model.Application.Id" class="form-control" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Display Name</label>
                                    <input value="@Model.Application.DisplayName" class="form-control" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Description</label>
                                    <input value="@Model.Application.Description" class="form-control" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Allow Self-Registration</label>
                                    <input value="@(Model.Application.AllowSelfRegistration ? "Yes" : "No")" class="form-control" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Active</label>
                                    <input value="@(Model.Application.IsActive ? "Yes" : "No")" class="form-control" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Created</label>
                                    <input value="@Model.Application.CreatedAt.ToLocalTime().ToString("g")" class="form-control" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="nav-roles" role="tabpanel" aria-labelledby="nav-roles-tab">
                        <a asp-action="AddRole" asp-route-id="@Model.Application.Id" class="btn btn-outline-primary">Add Role</a>
                        <br />  <br />
                        <table class="table table-bordered"
                               id="rolesTable"
                               data-toggle="table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Default</th>
                                    <th>Active</th>
                                    <th data-width="200"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var role in Model.Application.Roles ?? Enumerable.Empty<Codx.Auth.Data.Entities.Enterprise.EnterpriseApplicationRole>())
                                {
                                    <tr>
                                        <td>@role.Name</td>
                                        <td>@role.Description</td>
                                        <td>@(role.IsDefault ? "✓" : "")</td>
                                        <td>@(role.IsActive ? "Yes" : "No")</td>
                                        <td>
                                            <a href="@Url.Action("EditRole", new { appId = Model.Application.Id, roleId = role.Id })"
                                               class="btn btn-sm btn-outline-primary mr-1">Edit</a>
                                            @if (role.IsActive)
                                            {
                                                <form asp-action="DeactivateRole"
                                                      asp-route-id="@Model.Application.Id"
                                                      asp-route-roleId="@role.Id"
                                                      method="post" style="display:inline"
                                                      onsubmit="return confirm('Deactivate this role?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">Deactivate</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="tab-pane fade" id="nav-clients" role="tabpanel" aria-labelledby="nav-clients-tab">
                        <br />
                        @if (Model.LinkedClientIds.Any())
                        {
                            <table class="table table-bordered" data-toggle="table">
                                <thead>
                                    <tr><th>Client ID</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var clientId in Model.LinkedClientIds)
                                    {
                                        <tr><td><code>@clientId</code></td></tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">No linked clients.</p>
                        }
                    </div>

                    <div class="tab-pane fade" id="nav-assignments" role="tabpanel" aria-labelledby="nav-assignments-tab">
                        <br />

                        @if (TempData["AssignSuccess"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @TempData["AssignSuccess"]
                                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                            </div>
                        }
                        @if (TempData["AssignError"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @TempData["AssignError"]
                                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                            </div>
                        }

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label>Tenant</label>
                                <select id="assignTenantSelect" class="form-control">
                                    <option value="">-- Select Tenant --</option>
                                    @foreach (var t in Model.AllTenants)
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Company</label>
                                <select id="assignCompanySelect" class="form-control" disabled>
                                    <option value="">-- Select Company --</option>
                                </select>
                            </div>
                        </div>

                        <table class="table table-bordered" id="assignmentsTable">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Role</th>
                                    <th>Assigned At</th>
                                    <th>Assigned By</th>
                                    <th data-width="120"></th>
                                </tr>
                            </thead>
                            <tbody id="assignmentsTableBody">
                                <tr><td colspan="5" class="text-center text-muted">Select a tenant and company to view assignments.</td></tr>
                            </tbody>
                        </table>

                        <hr />
                        <h6>Assign Role</h6>
                        <form id="assignRoleForm" asp-action="Assign" asp-route-appId="@Model.Application.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="assignTenantId" name="TenantId" value="" />
                            <input type="hidden" id="assignCompanyId" name="CompanyId" value="" />
                            <div class="form-row align-items-end">
                                <div class="col-md-4">
                                    <label>User</label>
                                    <select id="assignUserSelect" name="UserId" class="form-control" disabled>
                                        <option value="">-- Select Company First --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label>Role</label>
                                    <select name="RoleId" class="form-control">
                                        <option value="">-- Select Role --</option>
                                        @foreach (var role in Model.Application.Roles?.Where(r => r.IsActive) ?? Enumerable.Empty<Codx.Auth.Data.Entities.Enterprise.EnterpriseApplicationRole>())
                                        {
                                            <option value="@role.Id">@role.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary" id="assignSubmitBtn" disabled>Assign</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var appId = '@Model.Application.Id';
    var antiForgeryToken = $('input[name="__RequestVerificationToken"]').first().val();

    var $tenantSel   = $('#assignTenantSelect');
    var $companySel  = $('#assignCompanySelect');
    var $userSel     = $('#assignUserSelect');
    var $submitBtn   = $('#assignSubmitBtn');
    var $tenantHid   = $('#assignTenantId');
    var $companyHid  = $('#assignCompanyId');
    var $tbody       = $('#assignmentsTableBody');

    $tenantSel.on('change', function () {
        var tenantId = $(this).val();
        $companySel.html('<option value="">-- Loading... --</option>').prop('disabled', true);
        $userSel.html('<option value="">-- Select Company First --</option>').prop('disabled', true);
        $submitBtn.prop('disabled', true);
        $tenantHid.val(tenantId);
        $companyHid.val('');
        $tbody.html('<tr><td colspan="5" class="text-center text-muted">Select a company to view assignments.</td></tr>');

        if (!tenantId) {
            $companySel.html('<option value="">-- Select Company --</option>');
            return;
        }

        $.getJSON('/Companies/GetCompaniesTableData', { tenantid: tenantId, offset: 0, limit: 500 }, function (data) {
            var opts = '<option value="">-- Select Company --</option>';
            (data.rows || []).forEach(function (c) {
                opts += '<option value="' + c.id + '">' + $('<span>').text(c.name).html() + '</option>';
            });
            $companySel.html(opts).prop('disabled', false);
        }).fail(function () {
            $companySel.html('<option value="">-- Error loading companies --</option>');
        });
    });

    $companySel.on('change', function () {
        var tenantId  = $tenantSel.val();
        var companyId = $(this).val();
        $userSel.html('<option value="">-- Loading... --</option>').prop('disabled', true);
        $submitBtn.prop('disabled', true);
        $companyHid.val(companyId);
        $tbody.html('<tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>');

        if (!companyId) {
            $userSel.html('<option value="">-- Select Company First --</option>');
            $tbody.html('<tr><td colspan="5" class="text-center text-muted">Select a company to view assignments.</td></tr>');
            return;
        }

        // Load assignments table
        $.getJSON('/Applications/' + appId + '/user-assignments', { tenantId: tenantId, companyId: companyId }, function (rows) {
            if (!rows || rows.length === 0) {
                $tbody.html('<tr><td colspan="5" class="text-center text-muted">No role assignments for this company.</td></tr>');
            } else {
                var html = '';
                rows.forEach(function (r) {
                    html += '<tr>' +
                        '<td>' + $('<span>').text(r.userEmail).html() + '</td>' +
                        '<td><span class="badge badge-secondary">' + $('<span>').text(r.roleName).html() + '</span></td>' +
                        '<td>' + new Date(r.assignedAt).toLocaleString() + '</td>' +
                        '<td>' + $('<span>').text(r.assignedByEmail).html() + '</td>' +
                        '<td>' +
                            '<form method="post" action="/Applications/' + appId + '/user-assignments/' + r.id + '/remove" style="display:inline" onsubmit="return confirm(\'Remove this assignment?\')">' +
                                '<input type="hidden" name="__RequestVerificationToken" value="' + antiForgeryToken + '" />' +
                                '<button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>' +
                            '</form>' +
                        '</td></tr>';
                });
                $tbody.html(html);
            }
        }).fail(function () {
            $tbody.html('<tr><td colspan="5" class="text-danger">Error loading assignments.</td></tr>');
        });

        // Load user picker
        $.getJSON('/Applications/' + appId + '/company-members', { tenantId: tenantId, companyId: companyId }, function (members) {
            var opts = '<option value="">-- Select User --</option>';
            (members || []).forEach(function (m) {
                opts += '<option value="' + m.userId + '">' + $('<span>').text(m.email).html() + '</option>';
            });
            $userSel.html(opts).prop('disabled', false);
            $submitBtn.prop('disabled', false);
        }).fail(function () {
            $userSel.html('<option value="">-- Error loading users --</option>');
        });
    });

    // If redirected back to this tab after an action, re-open it
    if (window.location.hash === '#nav-assignments' || '@(TempData.Peek("AssignSuccess") != null || TempData.Peek("AssignError") != null)' === 'True') {
        $('#nav-assignments-tab').tab('show');
    }
}());
</script>
}
