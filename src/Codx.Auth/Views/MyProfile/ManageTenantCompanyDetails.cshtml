@model CompanyDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("ManageTenant","MyProfile", new { id = Model.TenantId})">Manage Tenant</a></li>
        <li class="breadcrumb-item active" aria-current="page">Company</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">

        <div class="card">
            <div class="card-header">
                <nav>
                    <div class="nav nav-tabs" id="nav-tab" role="tablist">
                        <a class="nav-item nav-link active" id="nav-details-tab" data-toggle="tab" href="#nav-details" role="tab" aria-controls="nav-details" aria-selected="true">Details</a>
                        <a class="nav-item nav-link" id="nav-memberships-tab" data-toggle="tab" href="#nav-memberships" role="tab" aria-controls="nav-memberships" aria-selected="false">Memberships</a>
                        <a class="nav-item nav-link" id="nav-invitations-tab" data-toggle="tab" href="#nav-invitations" role="tab" aria-controls="nav-invitations" aria-selected="false">Invitations</a>
                    </div>
                </nav>
            </div>
            <div class="card-body">


                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane fade show active" id="nav-details" role="tabpanel" aria-labelledby="nav-details-tab">
                        <a asp-action="ManageTenantCompanyEdit" asp-controller="MyProfile" asp-route-id="@Model.Id" class="btn btn-outline-warning"><i class="fa fa-edit"></i>Edit</a>
                        <br />  <br />
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="form-group">
                                    <label>Name</label>
                                    <input asp-for="@Model.Name" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Email</label>
                                    <input asp-for="@Model.Email" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Phone</label>
                                    <input asp-for="@Model.Phone" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Address</label>
                                    <input asp-for="@Model.Address" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Description</label>
                                    <input asp-for="@Model.Description" class="form-control" readonly />
                                </div>

                            </div>
                        </div>
                    </div>

                    @*-- Memberships Tab --*@
                    <div class="tab-pane fade" id="nav-memberships" role="tabpanel" aria-labelledby="nav-memberships-tab">
                        <div class="mt-2 mb-2">
                            <a asp-controller="Memberships" asp-action="Create"
                               asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.Id"
                               class="btn btn-outline-success">Add Membership</a>
                        </div>
                        <table class="table table-bordered"
                               id="companyMembershipsTable"
                               data-toggle="table"
                               data-query-params="companyMembershipsTableParams"
                               data-pagination="true"
                               data-side-pagination="server"
                               data-page-size="10"
                               data-page-list="[10,25,50,100]"
                               data-ajax="companyMembershipsAjaxRequest">
                            <thead>
                                <tr>
                                    <th data-field="userEmail">User</th>
                                    <th data-field="roles">Roles</th>
                                    <th data-field="joinedAt" data-formatter="companyMembershipJoinedAtFormatter">Joined</th>
                                    <th data-field="membershipId" data-width="80" data-formatter="companyMembershipActionButtons"></th>
                                </tr>
                            </thead>
                        </table>
                    </div>

                    @*-- Invitations Tab --*@
                    <div class="tab-pane fade" id="nav-invitations" role="tabpanel" aria-labelledby="nav-invitations-tab">
                        <div class="mt-2 mb-2">
                            <a asp-controller="Invitations" asp-action="Create"
                               asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.Id"
                               class="btn btn-outline-success">Send Invitation</a>
                        </div>
                        <table class="table table-bordered"
                               id="companyInvitationsTable"
                               data-toggle="table"
                               data-query-params="companyInvitationsTableParams"
                               data-pagination="true"
                               data-side-pagination="server"
                               data-page-size="10"
                               data-page-list="[10,25,50,100]"
                               data-ajax="companyInvitationsAjaxRequest">
                            <thead>
                                <tr>
                                    <th data-field="email">Email</th>
                                    <th data-field="roles">Roles</th>
                                    <th data-field="status" data-formatter="companyInvitationStatusFormatter">Status</th>
                                    <th data-field="expiresAt" data-formatter="companyInvitationDateFormatter">Expires</th>
                                    <th data-field="createdAt" data-formatter="companyInvitationDateFormatter">Invited</th>
                                    <th data-field="invitationId" data-width="100" data-formatter="companyInvitationActionButtons"></th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts
{
    <script>
        var modelid = '@Model.Id';
        var tenantid = '@Model.TenantId';
    </script>

    <script>
        function companyMembershipsAjaxRequest(params) {
            var url = '@Url.Action("GetCompanyMembershipsTableData", "Memberships")';
            $.get(url + '?' + $.param(params.data)).then(function (res) {
                params.success(res)
            })
        };
        function companyMembershipsTableParams(params) {
            params.tenantId = tenantid;
            params.companyId = modelid;
            return params
        }
        function companyMembershipJoinedAtFormatter(value) {
            if (!value) return '';
            return new Date(value).toLocaleDateString();
        }
        function companyMembershipActionButtons(value, row) {
            return '<a class="btn btn-outline-info btn-sm" href="/Memberships/' + value + '" title="View membership"><i class="fa fa-file-alt"></i></a>'
        }

        function companyInvitationsAjaxRequest(params) {
            var url = '@Url.Action("GetTenantInvitationsTableData", "Invitations")';
            $.get(url + '?' + $.param(params.data)).then(function (res) {
                params.success(res)
            })
        };
        function companyInvitationsTableParams(params) {
            params.tenantId = tenantid;
            params.companyId = modelid;
            return params
        }
        function companyInvitationStatusFormatter(value) {
            var cls = value === 'Pending' ? 'badge-warning' : value === 'Accepted' ? 'badge-success' : 'badge-secondary';
            return '<span class="badge ' + cls + '">' + value + '</span>';
        }
        function companyInvitationDateFormatter(value) {
            if (!value) return '';
            return new Date(value).toLocaleDateString();
        }
        function companyInvitationActionButtons(value, row) {
            if (row.status !== 'Pending') return '';
            return '<form method="post" action="/Invitations/' + value + '/revoke" style="display:inline" onsubmit="return confirm(\'Revoke this invitation?\')">'
                + '<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name=__RequestVerificationToken]').first().val() + '" />'
                + '<input type="hidden" name="tenantId" value="' + tenantid + '" />'
                + '<input type="hidden" name="companyId" value="' + modelid + '" />'
                + '<button type="submit" class="btn btn-sm btn-outline-danger" title="Revoke invitation"><i class="fa fa-ban"></i></button>'
                + '</form>';
        }
    </script>

}