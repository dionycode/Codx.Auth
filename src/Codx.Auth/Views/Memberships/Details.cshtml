@using Codx.Auth.Data.Entities.Enterprise
@model UserMembership

@{
    ViewData["Title"] = "Membership Details";
    var availableRoles = ViewBag.AvailableRoles as List<WorkspaceRoleDefinition>;
    var applications = ViewBag.Applications as List<EnterpriseApplication>;
    var appRoleAssignments = ViewBag.AppRoleAssignments as List<UserApplicationRole>;
    bool isCompanyScoped = Model.CompanyId.HasValue;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        @if (User.IsInRole("PlatformAdministrator"))
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Tenants")">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId">Company</a></li>
            }
        }
        else
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
            <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId">Company</a></li>
            }
        }
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.CompanyId">Memberships</a></li>
        <li class="breadcrumb-item active" aria-current="page">Membership</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Membership — @(Model.User?.UserName ?? Model.UserId.ToString())</h5>
            </div>
            <div class="card-body">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                    </div>
                }
                @if (TempData["AppRoleError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["AppRoleError"]
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                    </div>
                }

                <dl class="row">
                    <dt class="col-sm-3">Tenant</dt>
                    <dd class="col-sm-9">@(Model.Tenant?.Name ?? Model.TenantId.ToString())</dd>
                    @if (Model.Company != null)
                    {
                        <dt class="col-sm-3">Company</dt>
                        <dd class="col-sm-9">@Model.Company.Name</dd>
                    }
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge badge-@(Model.Status == "Active" ? "success" : "secondary")">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-3">Joined</dt>
                    <dd class="col-sm-9">@Model.JoinedAt.ToLocalTime().ToString("g")</dd>
                </dl>

                <div class="mb-3">
                    @if (Model.Status == "Active")
                    {
                        <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Deactivate this membership?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Deactivate</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Reactivate" asp-route-id="@Model.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Reactivate this membership?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-success btn-sm">Reactivate</button>
                        </form>
                    }
                </div>

                <hr />

                <h6 class="font-weight-bold">Workspace Roles</h6>

                <table class="table table-sm">
                    <thead><tr><th>Role</th><th>Scope</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.MembershipRoles ?? Enumerable.Empty<UserMembershipRole>())
                        {
                            <tr>
                                <td>@(r.RoleDefinition?.DisplayName ?? r.RoleId.ToString())</td>
                                <td>@r.RoleDefinition?.ScopeType</td>
                                <td>
                                    <form asp-action="RevokeRole"
                                          asp-route-id="@Model.Id"
                                          asp-route-roleId="@r.Id"
                                          method="post" style="display:inline"
                                          onsubmit="return confirm('Remove this role?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (availableRoles?.Any() == true)
                {
                    <form asp-action="AddRole" asp-route-id="@Model.Id" method="post" class="form-inline mt-2">
                        @Html.AntiForgeryToken()
                        <select name="roleId" class="form-control mr-2">
                            @foreach (var role in availableRoles)
                            {
                                <option value="@role.Id">@role.DisplayName (@role.ScopeType)</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-outline-primary">Add Role</button>
                    </form>
                }

                @if (isCompanyScoped && applications != null)
                {
                    <hr />
                    <h6 class="font-weight-bold">Application Roles</h6>

                    @if (appRoleAssignments != null && appRoleAssignments.Any())
                    {
                        <table class="table table-sm mb-3">
                            <thead>
                                <tr>
                                    <th>Application</th>
                                    <th>Role</th>
                                    <th>Assigned At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in appRoleAssignments)
                                {
                                    <tr>
                                        <td><code>@a.ApplicationId</code></td>
                                        <td><span class="badge badge-secondary">@(a.Role?.Name ?? a.RoleId.ToString())</span></td>
                                        <td>@a.AssignedAt.ToLocalTime().ToString("g")</td>
                                        <td>
                                            <form asp-action="RemoveAppRole"
                                                  asp-route-id="@Model.Id"
                                                  asp-route-assignmentId="@a.Id"
                                                  method="post" style="display:inline"
                                                  onsubmit="return confirm('Remove this application role?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small">No application roles assigned.</p>
                    }

                    <form asp-action="AssignAppRole" asp-route-id="@Model.Id" method="post" class="form-row align-items-end">
                        @Html.AntiForgeryToken()
                        <div class="col-md-4">
                            <label class="small">Application</label>
                            <select id="appSelect" name="applicationId" class="form-control form-control-sm">
                                <option value="">-- Select Application --</option>
                                @foreach (var app in applications)
                                {
                                    <option value="@app.Id">@app.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="small">Role</label>
                            <select id="appRoleSelect" name="roleId" class="form-control form-control-sm" disabled>
                                <option value="">-- Select Application First --</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" id="assignAppRoleBtn" class="btn btn-outline-primary btn-sm" disabled>Assign</button>
                        </div>
                    </form>
                }

                <!-- <div class="mt-3">
                    @if (User.IsInRole("PlatformAdministrator"))
                    {
                        <a asp-action="Index" asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.CompanyId"
                           class="btn btn-secondary">Back to Memberships</a>
                    }
                    else
                    {
                        <a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId"
                           class="btn btn-secondary">Back to Tenant</a>
                    }
                </div> -->

            </div>
        </div>
    </div>
</div>

@section Scripts {
@if (isCompanyScoped && applications != null)
{
    var appRolesJson = new System.Text.StringBuilder();
    appRolesJson.Append("{");
    bool firstApp = true;
    foreach (var app in applications)
    {
        if (!firstApp) appRolesJson.Append(",");
        firstApp = false;
        appRolesJson.Append($"\"{app.Id}\":[");
        bool firstRole = true;
        foreach (var role in app.Roles?.Where(r => r.IsActive) ?? Enumerable.Empty<EnterpriseApplicationRole>())
        {
            if (!firstRole) appRolesJson.Append(",");
            firstRole = false;
            appRolesJson.Append($"{{\"id\":\"{role.Id}\",\"name\":{System.Text.Json.JsonSerializer.Serialize(role.Name)}}}");
        }
        appRolesJson.Append("]");
    }
    appRolesJson.Append("}");

    <script>
    (function () {
        var appRoles = @Html.Raw(appRolesJson.ToString());
        var $appSel  = $('#appSelect');
        var $roleSel = $('#appRoleSelect');
        var $btn     = $('#assignAppRoleBtn');

        $appSel.on('change', function () {
            var appId = $(this).val();
            var roles = appRoles[appId] || [];
            if (!appId || roles.length === 0) {
                $roleSel.html('<option value="">-- No roles available --</option>').prop('disabled', true);
                $btn.prop('disabled', true);
                return;
            }
            var opts = '<option value="">-- Select Role --</option>';
            roles.forEach(function (r) {
                opts += '<option value="' + r.id + '">' + $('<span>').text(r.name).html() + '</option>';
            });
            $roleSel.html(opts).prop('disabled', false);
            $btn.prop('disabled', false);
        });
    }());
    </script>
}
}
