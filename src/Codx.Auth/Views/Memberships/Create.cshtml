@using Codx.Auth.Data.Entities.Enterprise
@model Codx.Auth.ViewModels.MembershipCreateViewModel

@{
    ViewData["Title"] = "Add Membership";
    var availableRoles = ViewBag.AvailableRoles as List<WorkspaceRoleDefinition>;
    var tenantRoles = availableRoles?.Where(r => r.ScopeType == "Tenant").ToList();
    var companyRoles = availableRoles?.Where(r => r.ScopeType == "Company").ToList();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        @if (User.IsInRole("PlatformAdministrator"))
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Tenants")">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId">Company</a></li>
            }
        }
        else
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
            <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId">Company</a></li>
            }
        }
        <li class="breadcrumb-item active" aria-current="page">Add Membership</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Add Membership</h5>
            </div>
            <div class="card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TenantId" />
                    <input type="hidden" asp-for="CompanyId" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="UserName" />
                    <input type="hidden" asp-for="TenantScopeOnly" />

                    <div class="form-group">
                        <label asp-for="UserEmail"></label>
                        <div class="input-group">
                            @if (Model.UserId.HasValue)
                            {
                                <input asp-for="UserEmail" class="form-control" placeholder="Enter email address to search" readonly />
                            }
                            else
                            {
                                <input asp-for="UserEmail" class="form-control" placeholder="Enter email address to search" />
                            }
                            <div class="input-group-append">
                                <button type="submit" name="action" value="Search"
                                        class="btn btn-outline-secondary">Search</button>
                            </div>
                        </div>
                        <span asp-validation-for="UserEmail" class="text-danger"></span>
                    </div>

                    @if (Model.UserId.HasValue)
                    {
                        <div class="alert alert-info">
                            <strong>User found:</strong> @Model.UserName (@Model.UserEmail)
                        </div>

                        @if (tenantRoles?.Any() == true)
                        {
                            <div class="form-group">
                                <label class="font-weight-bold">Tenant Roles</label>
                                @foreach (var role in tenantRoles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="SelectedRoleIds" value="@role.Id"
                                               id="role_@role.Id"
                                               @(Model.SelectedRoleIds.Contains(role.Id) ? "checked" : "") />
                                        <label class="form-check-label" for="role_@role.Id">
                                            @role.DisplayName
                                        </label>
                                    </div>
                                }
                            </div>
                        }

                        @if (!Model.TenantScopeOnly && companyRoles?.Any() == true)
                        {
                            <div class="form-group">
                                <label class="font-weight-bold">Company Roles <small class="text-muted">(only if adding to a specific company)</small></label>
                                @foreach (var role in companyRoles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="SelectedRoleIds" value="@role.Id"
                                               id="role_@role.Id"
                                               @(Model.SelectedRoleIds.Contains(role.Id) ? "checked" : "") />
                                        <label class="form-check-label" for="role_@role.Id">
                                            @role.DisplayName
                                        </label>
                                    </div>
                                }
                            </div>
                        }

                        <div class="mt-3">
                            <button type="submit" name="action" value="Save"
                                    class="btn btn-primary">Save Membership</button>
                            @if (Model.CompanyId.HasValue && User.IsInRole("PlatformAdministrator"))
                            {
                                <a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId"
                                   class="btn btn-secondary ml-2">Cancel</a>
                            }
                            else if (Model.CompanyId.HasValue)
                            {
                                <a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId"
                                   class="btn btn-secondary ml-2">Cancel</a>
                            }
                            else if (User.IsInRole("PlatformAdministrator"))
                            {
                                <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId"
                                   class="btn btn-secondary ml-2">Cancel</a>
                            }
                            else
                            {
                                <a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId"
                                   class="btn btn-secondary ml-2">Cancel</a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mt-3">
                            @if (Model.CompanyId.HasValue && User.IsInRole("PlatformAdministrator"))
                            {
                                <a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId"
                                   class="btn btn-secondary">Cancel</a>
                            }
                            else if (Model.CompanyId.HasValue)
                            {
                                <a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId"
                                   class="btn btn-secondary">Cancel</a>
                            }
                            else if (User.IsInRole("PlatformAdministrator"))
                            {
                                <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId"
                                   class="btn btn-secondary">Cancel</a>
                            }
                            else
                            {
                                <a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId"
                                   class="btn btn-secondary">Cancel</a>
                            }
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
