
@model ClientAddViewModel



@{
    ViewData["Title"] = "Add";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Clients")">Clients</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">

        <div class="card">
            <div class="card-header">
                Add Client
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-12">

                        <partial name="_ValidationSummary" />

                    </div>
                </div>

                <form asp-action="Add">

                    <div class="form-group">
                        <label>ClientID</label>
                        <input asp-for="@Model.ClientId" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Client Name</label>
                        <input asp-for="@Model.ClientName" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <input asp-for="@Model.Description" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="@Model.ApplicationId">Application (optional)</label>
                        <select asp-for="@Model.ApplicationId" class="form-control">
                            <option value="">— None —</option>
                            @if (ViewBag.Applications != null)
                            {
                                foreach (var app in (System.Collections.IEnumerable)ViewBag.Applications)
                                {
                                    var appItem = (dynamic)app;
                                    <option value="@appItem.Id">@appItem.DisplayName (@appItem.Id)</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="@Model.AllowSelfRegistration" class="form-check-input" />
                        <label class="form-check-label" asp-for="@Model.AllowSelfRegistration">Allow Self-Registration</label>
                    </div>

                    <div class="form-group">
                        <input type="submit" class="btn btn-primary" value="Save" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
