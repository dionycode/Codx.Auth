@model Codx.Auth.ViewModels.EmailTemplates.EmailTemplateDeleteViewModel

@{
    ViewData["Title"] = $"Reset — {Model.TemplateTypeLabel}";
    bool isPlatformAdmin = User.IsInRole("PlatformAdministrator");
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        @if (isPlatformAdmin && !Model.TenantId.HasValue)
        {
            <li class="breadcrumb-item"><a asp-action="Index">Email Templates</a></li>
        }
        else if (isPlatformAdmin)
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Tenants")">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId">@Model.TenantName</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-tenantId="@Model.TenantId">Email Templates</a></li>
        }
        else
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
            <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId">@Model.TenantName</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-tenantId="@Model.TenantId">Email Templates</a></li>
        }
        <li class="breadcrumb-item active" aria-current="page">Reset @Model.TemplateTypeLabel</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                Reset — @Model.TemplateTypeLabel
            </div>
            <div class="card-body">

                <div class="alert alert-warning">
                    <strong>Warning:</strong> Resetting this template will remove the current custom body.
                    After this action, the system will fall back to: <strong>@Model.FallbackLabel</strong>.
                </div>

                <p>Are you sure you want to reset the <strong>@Model.TemplateTypeLabel</strong> template
                    @(Model.TenantId.HasValue ? $"for <strong>{Model.TenantName}</strong>" : "at the global level")?
                </p>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TenantId" />
                    <input type="hidden" asp-for="TemplateType" />
                    <input type="hidden" asp-for="TemplateTypeLabel" />
                    <input type="hidden" asp-for="TenantName" />
                    <input type="hidden" asp-for="FallbackLabel" />

                    <div class="d-flex gap-2 mt-3">
                        <input type="submit" class="btn btn-danger" value="Yes, Reset" />
                        <a asp-action="Index" asp-route-tenantId="@Model.TenantId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
