@model Codx.Auth.ViewModels.EmailTemplates.EmailTemplateIndexViewModel

@{
    ViewData["Title"] = "Email Templates";
    bool isPlatformAdmin = User.IsInRole("PlatformAdministrator");
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
        @if (isPlatformAdmin && !Model.TenantId.HasValue)
        {
            <li class="breadcrumb-item active" aria-current="page">Email Templates</li>
        }
        else if (isPlatformAdmin)
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Tenants")">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId">@Model.TenantName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Email Templates</li>
        }
        else
        {
            <li class="breadcrumb-item"><a href="@Url.Action("Index","MyProfile")">My Profile</a></li>
            <li class="breadcrumb-item"><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId">@Model.TenantName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Email Templates</li>
        }
    </ol>
</nav>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    @(Model.TenantId.HasValue ? $"{Model.TenantName} — Email Templates" : "Global Email Templates")
                </h5>
            </div>
            <div class="card-body">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <p class="text-muted">
                    The resolution order for each email type is: <strong>Tenant Override → Global Default → Built-in Default</strong>.
                    Editing a template here @(Model.TenantId.HasValue ? "sets a tenant-level override" : "sets the global default") for all tenants without their own override.
                </p>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Email Type</th>
                            <th>Current Source</th>
                            <th>Body Preview</th>
                            <th style="width:200px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td><strong>@row.TemplateTypeLabel</strong></td>
                                <td>
                                    @{
                                        var badgeClass = row.SourceLabel switch
                                        {
                                            "Custom"         => "badge bg-success",
                                            "Global Default" => "badge bg-info text-dark",
                                            _                => "badge bg-secondary"
                                        };
                                    }
                                    <span class="@badgeClass">@row.SourceLabel</span>
                                </td>
                                <td>
                                    @if (row.Body is not null)
                                    {
                                        <small class="text-muted font-monospace">
                                            @(row.Body.Length > 120 ? row.Body.Substring(0, 120) + "…" : row.Body)
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted fst-italic">Using built-in default</small>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit"
                                       asp-route-type="@row.TemplateType"
                                       asp-route-tenantId="@Model.TenantId"
                                       class="btn btn-sm btn-outline-primary">Edit</a>

                                    @if (row.CanReset)
                                    {
                                        <a asp-action="Delete"
                                           asp-route-type="@row.TemplateType"
                                           asp-route-tenantId="@Model.TenantId"
                                           class="btn btn-sm btn-outline-danger ms-1">Reset</a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary ms-1" disabled title="Nothing to reset — using built-in">Reset</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>
