@model Codx.Auth.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
    Layout = "_BlankLayout";
}

<div class="login_wrapper">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h2>Reset Password</h2>
                </div>
                <div class="card-body">
                    <form asp-action="ResetPassword" method="post">
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Token" />

                        <div asp-validation-summary="All" class="text-danger mb-2"></div>

                        <div class="form-group">
                            <input type="password" class="form-control" placeholder="New password" asp-for="NewPassword" autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <input type="password" class="form-control" placeholder="Confirm new password" asp-for="ConfirmPassword" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button class="btn btn-primary" type="submit">Reset Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
