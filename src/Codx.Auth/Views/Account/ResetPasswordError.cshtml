@{
    ViewData["Title"] = "Invalid Reset Link";
    Layout = "_BlankLayout";
}

<div class="login_wrapper">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h2>Invalid Reset Link</h2>
                </div>
                <div class="card-body">
                    <p>This password reset link is invalid or has expired.</p>
                    <p class="text-muted">Reset links are single-use and expire after 1 hour.</p>

                    <div class="mt-3">
                        <a asp-controller="Account" asp-action="ForgotPassword" class="register-link-small">Request a new link</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
