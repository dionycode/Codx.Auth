@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_BlankLayout";
}

<div class="login_wrapper">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h2>Check Your Email</h2>
                </div>
                <div class="card-body">
                    <p>If that email is registered, a reset link has been sent.</p>
                    <p class="text-muted">Please check your inbox and click the link to reset your password. The link expires in 1 hour.</p>

                    <div class="mt-3">
                        <a asp-controller="Account" asp-action="Login" class="register-link-small">Back to Sign In</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
