@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-8 py-10 max-w-3xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-4">@ViewData["Title"]</h1>
    <p class="text-sm text-gray-700 mb-4">Your privacy is important to us. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our site and services.</p>
    <h2 class="text-lg font-semibold text-gray-900 mb-2">Information We Collect</h2>
    <p class="text-sm text-gray-700">We may collect personal information you provide directly to us, such as your name, email address, and authentication credentials.</p>
</div>
