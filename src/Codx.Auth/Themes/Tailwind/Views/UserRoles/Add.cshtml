@model UserRoleAddViewModel

@{
    ViewData["Title"] = "Add User Role";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Users", Url.Action("Index","Users")), ("User", Url.Action("Details","Users", new { id = Model.UserId })), ("Add Role", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />
    <form asp-action="Add" class="space-y-5">
        <input type="hidden" asp-for="UserId" />
        <div>
            <label asp-for="RoleId" class="block text-sm/6 font-medium text-gray-900">Role</label>
            <div class="mt-2">
                <select asp-for="RoleId" asp-items="Model.Roles" class="block w-full rounded-md border-0 py-2 pl-3 pr-8 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600"></select>
            </div>
        </div>
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="Details" asp-controller="Users" asp-route-id="@Model.UserId" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>
