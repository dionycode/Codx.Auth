@using Codx.Auth.Data.Entities.Enterprise
@model Codx.Auth.ViewModels.Invitations.CreateInvitationViewModel

@{
    ViewData["Title"] = "Send Invitation";
    var tenantRoles = Model.AvailableRoles?.Where(r => r.ScopeType == "Tenant").ToList();
    var companyRoles = Model.AvailableRoles?.Where(r => r.ScopeType == "Company").ToList();
}

<nav aria-label="Breadcrumb" class="mb-4">
    <ol class="flex items-center gap-x-2 text-sm text-gray-500">
        <li><a href="@Url.Action("Index","Home")" class="hover:text-gray-700">Home</a></li>
        <li><span class="mx-1">/</span></li>
        @if (User.IsInRole("PlatformAdministrator"))
        {
            <li><a href="@Url.Action("Index","Tenants")" class="hover:text-gray-700">Tenants</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId" class="hover:text-gray-700">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li><span class="mx-1">/</span></li>
                <li><a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId" class="hover:text-gray-700">Company</a></li>
            }
        }
        else
        {
            <li><a href="@Url.Action("Index","MyProfile")" class="hover:text-gray-700">My Profile</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId" class="hover:text-gray-700">Tenant</a></li>
            @if (Model.CompanyId.HasValue)
            {
                <li><span class="mx-1">/</span></li>
                <li><a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId" class="hover:text-gray-700">Company</a></li>
            }
        }
        <li><span class="mx-1">/</span></li>
        <li class="text-gray-900 font-medium" aria-current="page">Send Invitation</li>
    </ol>
</nav>

<div class="mb-6"><h1 class="text-2xl font-semibold text-gray-900">Send Invitation</h1></div>

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />
    <form asp-action="Create" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TenantId" />
        <input type="hidden" asp-for="CompanyId" />
        <div>
            <label asp-for="Email" class="block text-sm/6 font-medium text-gray-900">Email</label>
            <div class="mt-2"><input asp-for="Email" type="email" autocomplete="email" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div>
            <span asp-validation-for="Email" class="text-sm text-red-600"></span>
        </div>

        @if (tenantRoles?.Any() == true)
        {
            <fieldset>
                <legend class="block text-sm font-semibold text-gray-900 mb-2">Tenant Roles</legend>
                @foreach (var role in tenantRoles)
                {
                    <div class="flex items-center gap-x-2 mb-1">
                        <input type="checkbox" name="SelectedRoleIds" value="@role.Id" id="role_@role.Id"
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600"
                               @(Model.SelectedRoleIds?.Contains(role.Id) == true ? "checked" : "") />
                        <label for="role_@role.Id" class="text-sm text-gray-900">@role.DisplayName</label>
                    </div>
                }
            </fieldset>
        }

        @if (companyRoles?.Any() == true)
        {
            <fieldset>
                <legend class="block text-sm font-semibold text-gray-900 mb-2">Company Roles</legend>
                @foreach (var role in companyRoles)
                {
                    <div class="flex items-center gap-x-2 mb-1">
                        <input type="checkbox" name="SelectedRoleIds" value="@role.Id" id="role_@role.Id"
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600"
                               @(Model.SelectedRoleIds?.Contains(role.Id) == true ? "checked" : "") />
                        <label for="role_@role.Id" class="text-sm text-gray-900">@role.DisplayName</label>
                    </div>
                }
            </fieldset>
        }

        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Send Invitation</button>
            @if (Model.CompanyId.HasValue && User.IsInRole("PlatformAdministrator"))
            {
                <a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId"
                   class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
            }
            else if (Model.CompanyId.HasValue)
            {
                <a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@Model.CompanyId"
                   class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
            }
            else if (User.IsInRole("PlatformAdministrator"))
            {
                <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantId"
                   class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
            }
            else
            {
                <a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@Model.TenantId"
                   class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
            }
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
