@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("My Profile", Url.Action("Index","MyProfile")), ("Change Password", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />
    <form asp-action="ChangePassword" asp-controller="MyProfile" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <div><label asp-for="CurrentPassword" class="block text-sm/6 font-medium text-gray-900">Current Password</label><div class="mt-2"><input asp-for="CurrentPassword" type="password" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div><label asp-for="NewPassword" class="block text-sm/6 font-medium text-gray-900">New Password</label><div class="mt-2"><input asp-for="NewPassword" type="password" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div><label asp-for="ConfirmPassword" class="block text-sm/6 font-medium text-gray-900">Confirm Password</label><div class="mt-2"><input asp-for="ConfirmPassword" type="password" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Change Password</button>
            <a asp-action="Index" asp-controller="MyProfile" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
