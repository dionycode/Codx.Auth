@model CompanyUserAddViewModel

@{
    ViewData["Title"] = "Add Company User";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("My Profile", Url.Action("Index","MyProfile")), ("Company", Url.Action("ManageTenantCompanyDetails","MyProfile", new { id = Model.CompanyId })), ("Add User", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />
    <form asp-action="ManageTenantCompanyUserAdd" asp-controller="MyProfile" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CompanyId" />
        <div><label asp-for="UserEmail" class="block text-sm/6 font-medium text-gray-900">User Email</label><div class="mt-2"><input asp-for="UserEmail" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        @if (Model.UserId != null)
        {
            <div><label asp-for="UserId" class="block text-sm/6 font-medium text-gray-900">User ID</label><div class="mt-2"><input asp-for="UserId" class="block w-full rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300" readonly /></div></div>
            <div><label asp-for="UserName" class="block text-sm/6 font-medium text-gray-900">Username</label><div class="mt-2"><input asp-for="UserName" class="block w-full rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300" readonly /></div></div>
        }
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="ManageTenantCompanyDetails" asp-controller="MyProfile" asp-route-id="@Model.CompanyId" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>
