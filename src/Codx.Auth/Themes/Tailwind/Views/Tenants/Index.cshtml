@{
    ViewData["Title"] = "Tenants";
}

<partial name="_PageHeading" />

<div class="sm:flex sm:items-center mb-4">
    <div class="sm:flex-auto"></div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <a asp-action="Add" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">Add Tenant</a>
    </div>
</div>

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Email</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white" id="tenantsBody">
                <tr><td colspan="3" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
            </tbody>
        </table>
    </div>
    <div class="flex items-center justify-between border-t border-gray-200 bg-white px-4 py-3 sm:px-6" id="tenantsPagination"></div>
</div>

@section Scripts {
<script>
(function () {
    var url = '@Url.Action("GetTenantsTableData","Tenants")';
    function loadPage(offset) {
        fetch(url + '?offset=' + offset + '&limit=10')
            .then(function (r) { return r.json(); })
            .then(function (res) {
                var tbody = document.getElementById('tenantsBody');
                tbody.innerHTML = '';
                var rows = res.rows || [];
                if (rows.length === 0) {
                    var tr = document.createElement('tr');
                    var td = document.createElement('td');
                    td.colSpan = 3;
                    td.className = 'px-6 py-4 text-sm text-gray-500';
                    td.textContent = 'No tenants found.';
                    tr.appendChild(td);
                    tbody.appendChild(tr);
                    return;
                }
                rows.forEach(function (row) {
                    var tr = document.createElement('tr');
                    tr.className = 'hover:bg-gray-50';
                    var tdName = document.createElement('td');
                    tdName.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900';
                    tdName.textContent = row.name;
                    var tdEmail = document.createElement('td');
                    tdEmail.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-500';
                    tdEmail.textContent = row.email;
                    var tdAct = document.createElement('td');
                    tdAct.className = 'whitespace-nowrap px-6 py-4 text-right text-sm font-medium';
                    ['Details', 'Edit', 'Delete'].forEach(function(action) {
                        var a = document.createElement('a');
                        a.href = '/Tenants/' + action + '/' + row.id;
                        a.className = action === 'Delete' ? 'text-red-600 hover:text-red-900 ml-3' : 'text-indigo-600 hover:text-indigo-900 ml-3';
                        a.textContent = action;
                        tdAct.appendChild(a);
                    });
                    tr.appendChild(tdName);
                    tr.appendChild(tdEmail);
                    tr.appendChild(tdAct);
                    tbody.appendChild(tr);
                });
            });
    }
    loadPage(0);
}());
</script>
}
