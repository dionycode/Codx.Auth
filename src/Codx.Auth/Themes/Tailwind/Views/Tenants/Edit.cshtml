@model TenantEditViewModel

@{
    ViewData["Title"] = "Edit Tenant";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Tenants", Url.Action("Index","Tenants")), ("Tenant", Url.Action("Details","Tenants", new { id = Model.Id })), ("Edit", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />

    <form asp-action="Edit" class="space-y-5">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="Name" class="block text-sm/6 font-medium text-gray-900">Name</label>
            <div class="mt-2">
                <input asp-for="Name" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="Email" class="block text-sm/6 font-medium text-gray-900">Email</label>
            <div class="mt-2">
                <input asp-for="Email" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="Phone" class="block text-sm/6 font-medium text-gray-900">Phone</label>
            <div class="mt-2">
                <input asp-for="Phone" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="Address" class="block text-sm/6 font-medium text-gray-900">Address</label>
            <div class="mt-2">
                <input asp-for="Address" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm/6 font-medium text-gray-900">Description</label>
            <div class="mt-2">
                <input asp-for="Description" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>

    </form>
</div>
