@model UserCompanyEditViewModel

@{
    ViewData["Title"] = "Remove User Company";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("User", Url.Action("Details","Users", new { id = Model.UserId })), ("Remove Company", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <div class="rounded-md bg-red-50 p-4 ring-1 ring-inset ring-red-600/10 mb-6">
        <p class="text-sm font-medium text-red-800">Are you sure you want to remove this company from the user?</p>
    </div>
    <dl class="divide-y divide-gray-100 mb-6">
        <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Company</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.CompanyName</dd></div>
        <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Tenant</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.TenantName</dd></div>
    </dl>
    <form asp-action="Delete" class="flex gap-x-3">
        <input type="hidden" asp-for="CompanyId" />
        <input type="hidden" asp-for="UserId" />
        <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500">Remove</button>
        <a asp-action="Details" asp-controller="Users" asp-route-id="@Model.UserId" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
    </form>
</div>
