@model CompanyDetailsViewModel

@{
    ViewData["Title"] = "Company Details";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Tenants", Url.Action("Index","Tenants")), ("Tenant", Url.Action("Details","Tenants", new { id = Model.TenantId })), (Model.Name, (string?)null) } })' />
<partial name="_PageHeading" />

<div class="mb-4 flex gap-x-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-700 shadow-xs ring-1 ring-inset ring-red-300 hover:bg-red-50">Delete</a>
</div>

<div x-data="{ tab: 'details' }">
    <div class="border-b border-gray-200 mb-6">
        <nav class="-mb-px flex space-x-6">
            <button @@click="tab='details'" :class="tab==='details' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Details</button>
            <button @@click="tab='memberships'; loadMemberships()" :class="tab==='memberships' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Memberships</button>
            <button @@click="tab='invitations'; loadInvitations()" :class="tab==='invitations' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Invitations</button>
        </nav>
    </div>

    <div x-show="tab==='details'">
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-6">
            <dl class="divide-y divide-gray-100">
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Name</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Email</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Email</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Phone</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Phone</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Address</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Address</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Description</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Description</dd></div>
            </dl>
        </div>
    </div>

    <div x-show="tab==='memberships'">
        <div class="mb-3">
            <a asp-action="Add" asp-controller="CompanyUsers" asp-route-tenantId="@Model.TenantId" asp-route-companyId="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add Member</a>
        </div>
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">User</th><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Joined</th><th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500">Actions</th></tr></thead>
                <tbody id="tbody-memberships" class="divide-y divide-gray-100 bg-white"></tbody>
            </table>
        </div>
    </div>

    <div x-show="tab==='invitations'">
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Email</th><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Status</th><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Date</th></tr></thead>
                <tbody id="tbody-invitations" class="divide-y divide-gray-100 bg-white"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
var modelId = '@Model.Id';
var tenantId = '@Model.TenantId';
var membershipsLoaded = false;
var invitationsLoaded = false;

function loadMemberships() {
    if (membershipsLoaded) return; membershipsLoaded = true;
    fetch('@Url.Action("GetCompanyMembershipsTableData","Memberships")?offset=0&limit=200&tenantId=' + tenantId + '&companyId=' + modelId)
        .then(function(r) { return r.json(); })
        .then(function(res) {
            var tbody = document.getElementById('tbody-memberships');
            var rows = res.rows || [];
            if (!rows.length) { var tr = document.createElement('tr'); var td = document.createElement('td'); td.colSpan = 3; td.className = 'px-6 py-4 text-sm text-gray-500 text-center'; td.textContent = 'No records found.'; tr.appendChild(td); tbody.appendChild(tr); return; }
            rows.forEach(function(row) {
                var tr = document.createElement('tr'); tr.className = 'hover:bg-gray-50';
                ['userName','joinedAt'].forEach(function(col) { var td = document.createElement('td'); td.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900'; td.textContent = row[col] || ''; tr.appendChild(td); });
                var tdAct = document.createElement('td'); tdAct.className = 'whitespace-nowrap px-6 py-4 text-right text-sm';
                var a = document.createElement('a'); a.href = '/Memberships/' + row.id; a.className = 'text-indigo-600 hover:text-indigo-500'; a.textContent = 'View';
                tdAct.appendChild(a); tr.appendChild(tdAct); tbody.appendChild(tr);
            });
        });
}

function loadInvitations() {
    if (invitationsLoaded) return; invitationsLoaded = true;
    fetch('@Url.Action("GetTenantInvitationsTableData","Invitations")?offset=0&limit=200&tenantId=' + tenantId + '&companyId=' + modelId)
        .then(function(r) { return r.json(); })
        .then(function(res) {
            var tbody = document.getElementById('tbody-invitations');
            var rows = res.rows || [];
            if (!rows.length) { var tr = document.createElement('tr'); var td = document.createElement('td'); td.colSpan = 3; td.className = 'px-6 py-4 text-sm text-gray-500 text-center'; td.textContent = 'No records found.'; tr.appendChild(td); tbody.appendChild(tr); return; }
            rows.forEach(function(row) {
                var tr = document.createElement('tr'); tr.className = 'hover:bg-gray-50';
                ['email','status','createdAt'].forEach(function(col) { var td = document.createElement('td'); td.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900'; td.textContent = row[col] || ''; tr.appendChild(td); });
                tbody.appendChild(tr);
            });
        });
}
</script>
}
