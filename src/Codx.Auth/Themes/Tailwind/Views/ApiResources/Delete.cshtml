@model ApiResourceEditViewModel

@{
    ViewData["Title"] = "Delete API Resource";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("API Resources", Url.Action("Index","ApiResources")), (Model.Name, Url.Action("Details","ApiResources", new { id = Model.Id })), ("Delete", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <div class="rounded-md bg-red-50 p-4 ring-1 ring-inset ring-red-600/10 mb-6">
        <p class="text-sm font-medium text-red-800">Are you sure you want to delete this API resource?</p>
    </div>
    <dl class="divide-y divide-gray-100 mb-6">
        <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Name</dd></div>
        <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Display Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.DisplayName</dd></div>
        <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Description</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Description</dd></div>
    </dl>
    <form asp-action="Delete" class="flex gap-x-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
    </form>
</div>
