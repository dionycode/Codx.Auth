@model ApiResourceDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("API Resources", Url.Action("Index","ApiResources")), (Model.Name, (string?)null) } })' />
<partial name="_PageHeading" />

<div class="mb-4 flex gap-x-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-700 shadow-xs ring-1 ring-inset ring-red-300 hover:bg-red-50">Delete</a>
</div>

<div x-data="{ tab: 'details' }">
    <div class="border-b border-gray-200">
        <nav class="-mb-px flex flex-wrap gap-x-6" aria-label="Tabs">
            @foreach (var t in new[] { ("details","Details"),("claims","Claims"),("scopes","Scopes"),("secrets","Secrets"),("properties","Properties") })
            {
                <button type="button" @@click="tab = '@t.Item1'"
                        :class="tab === '@t.Item1' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'"
                        class="whitespace-nowrap border-b-2 px-1 py-4 text-sm font-medium">@t.Item2</button>
            }
        </nav>
    </div>

    <div x-show="tab === 'details'" x-cloak class="mt-6">
        <dl class="divide-y divide-gray-100">
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Name</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Display Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.DisplayName</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Enabled</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@(Model.Enabled ? "Yes" : "No")</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Description</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Description</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Allowed Token Signing Algorithms</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.AllowedAccessTokenSigningAlgorithms</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Show in Discovery Document</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@(Model.ShowInDiscoveryDocument ? "Yes" : "No")</dd></div>
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Require Resource Indicator</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@(Model.RequireResourceIndicator ? "Yes" : "No")</dd></div>
        </dl>
    </div>

    <div x-show="tab === 'claims'" x-cloak class="mt-6">
        <div class="mb-4"><a asp-action="Add" asp-controller="ApiResourceClaims" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add</a></div>
        <div class="overflow-hidden rounded-lg ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-200 bg-white" id="claimsBody">
                    <tr><td colspan="2" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div x-show="tab === 'scopes'" x-cloak class="mt-6">
        <div class="mb-4"><a asp-action="Add" asp-controller="ApiResourceScopes" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add</a></div>
        <div class="overflow-hidden rounded-lg ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Scope</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-200 bg-white" id="scopesBody">
                    <tr><td colspan="2" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div x-show="tab === 'secrets'" x-cloak class="mt-6">
        <div class="mb-4"><a asp-action="Add" asp-controller="ApiResourceSecrets" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add</a></div>
        <div class="overflow-hidden rounded-lg ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-200 bg-white" id="secretsBody">
                    <tr><td colspan="3" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div x-show="tab === 'properties'" x-cloak class="mt-6">
        <div class="mb-4"><a asp-action="Add" asp-controller="ApiResourceProperties" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add</a></div>
        <div class="overflow-hidden rounded-lg ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Value</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-200 bg-white" id="propertiesBody">
                    <tr><td colspan="3" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var id = '@Model.Id';
    function makeActions(entity, rowId) {
        var frag = document.createDocumentFragment();
        ['Details','Edit','Delete'].forEach(function(a) {
            var link = document.createElement('a');
            link.href = '/' + entity + '/' + a + '/' + rowId;
            link.className = a === 'Delete' ? 'text-red-600 hover:text-red-900 ml-3 text-sm' : 'text-indigo-600 hover:text-indigo-900 ml-3 text-sm';
            link.textContent = a;
            frag.appendChild(link);
        });
        return frag;
    }
    function fillTable(tbodyId, url, params, cols) {
        fetch(url + '?' + new URLSearchParams(Object.assign({ offset: 0, limit: 200 }, params)))
            .then(function(r) { return r.json(); })
            .then(function(res) {
                var tbody = document.getElementById(tbodyId);
                tbody.innerHTML = '';
                var rows = res.rows || [];
                if (!rows.length) {
                    var tr = document.createElement('tr');
                    var td = document.createElement('td'); td.colSpan = cols.length + 1; td.className = 'px-6 py-4 text-sm text-gray-500'; td.textContent = 'No items.';
                    tr.appendChild(td); tbody.appendChild(tr); return;
                }
                rows.forEach(function(row) {
                    var tr = document.createElement('tr'); tr.className = 'hover:bg-gray-50';
                    cols.forEach(function(col) {
                        var td = document.createElement('td'); td.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900'; td.textContent = row[col] || '';
                        tr.appendChild(td);
                    });
                    var tdAct = document.createElement('td'); tdAct.className = 'whitespace-nowrap px-6 py-4 text-right';
                    tdAct.appendChild(makeActions(params.controller, row.id));
                    tr.appendChild(tdAct);
                    tbody.appendChild(tr);
                });
            });
    }
    fillTable('claimsBody',     '@Url.Action("GetApiResourceClaimsTableData","ApiResourceClaims")',         { apiresourceid: id, controller: 'ApiResourceClaims' },     ['type']);
    fillTable('scopesBody',     '@Url.Action("GetApiResourceScopesTableData","ApiResourceScopes")',         { apiresourceid: id, controller: 'ApiResourceScopes' },     ['scope']);
    fillTable('secretsBody',    '@Url.Action("GetApiResourceSecretsTableData","ApiResourceSecrets")',       { apiresourceid: id, controller: 'ApiResourceSecrets' },    ['type','description']);
    fillTable('propertiesBody', '@Url.Action("GetApiResourcePropertiesTableData","ApiResourceProperties")', { apiresourceid: id, controller: 'ApiResourceProperties' }, ['key','value']);
}());
</script>
}
