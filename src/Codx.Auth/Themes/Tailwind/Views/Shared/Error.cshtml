@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-8 py-10 max-w-2xl">
    <div class="rounded-md bg-red-50 p-4 ring-1 ring-inset ring-red-600/10 mb-6">
        <h1 class="text-lg font-semibold text-red-800">An error occurred.</h1>
        <p class="mt-1 text-sm text-red-700">An error occurred while processing your request.</p>
    </div>
    @if (Model.ShowRequestId)
    {
        <dl class="divide-y divide-gray-100">
            <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Request ID</dt><dd class="mt-1 text-sm font-mono text-gray-700 sm:col-span-2 sm:mt-0">@Model.RequestId</dd></div>
        </dl>
    }
</div>
