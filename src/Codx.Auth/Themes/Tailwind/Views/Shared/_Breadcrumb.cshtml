@{
    var items = ViewData["BreadcrumbItems"] as IEnumerable<(string Label, string? Url)>
                ?? Enumerable.Empty<(string, string?)>();
    var itemList = items.ToList();
}
@if (itemList.Any())
{
    <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center space-x-2">
            @for (int i = 0; i < itemList.Count; i++)
            {
                var item = itemList[i];
                var isLast = i == itemList.Count - 1;
                if (i > 0)
                {
                    <li>
                        <svg class="h-4 w-4 shrink-0 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                        </svg>
                    </li>
                }
                <li>
                    @if (isLast || item.Url is null)
                    {
                        <span aria-current="page" class="text-sm font-medium text-gray-500">@item.Label</span>
                    }
                    else
                    {
                        <a href="@item.Url" class="text-sm font-medium text-gray-500 hover:text-gray-700">@item.Label</a>
                    }
                </li>
            }
        </ol>
    </nav>
}
