@{
    var title = ViewData["Title"] as string ?? string.Empty;
    var subtitle = ViewData["PageSubtitle"] as string;
}
<div class="sm:flex sm:items-center mb-6">
    <div class="sm:flex-auto">
        <h1 class="text-base font-semibold text-gray-900">@title</h1>
        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <p class="mt-2 text-sm text-gray-700">@subtitle</p>
        }
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        @* Callers render action buttons after this partial *@
    </div>
</div>
