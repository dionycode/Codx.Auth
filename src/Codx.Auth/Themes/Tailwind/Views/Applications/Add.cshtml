@model Codx.Auth.ViewModels.Applications.ApplicationAddViewModel

@{
    ViewData["Title"] = "Add Application";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Applications", Url.Action("Index","Applications")), ("Add Application", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />

    <form asp-action="Add" class="space-y-5">
        @Html.AntiForgeryToken()

        <div>
            <label asp-for="Id" class="block text-sm/6 font-medium text-gray-900">Application ID</label>
            <div class="mt-2">
                <input asp-for="Id" placeholder="e.g. my-app" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
            <p class="mt-1 text-xs text-gray-500">Lowercase letters, numbers and hyphens only. Used as the unique identifier and cannot be changed.</p>
        </div>
        <div>
            <label asp-for="DisplayName" class="block text-sm/6 font-medium text-gray-900">Display Name</label>
            <div class="mt-2">
                <input asp-for="DisplayName" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>
        <div>
            <label asp-for="Description" class="block text-sm/6 font-medium text-gray-900">Description</label>
            <div class="mt-2">
                <textarea asp-for="Description" rows="3" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6"></textarea>
            </div>
        </div>
        <div class="flex items-center gap-x-3">
            <input asp-for="AllowSelfRegistration" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
            <label asp-for="AllowSelfRegistration" class="text-sm/6 font-medium text-gray-900">Allow Self-Registration</label>
        </div>
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="Index" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
