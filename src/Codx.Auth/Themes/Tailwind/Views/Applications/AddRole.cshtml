@model Codx.Auth.ViewModels.Applications.ApplicationRoleAddViewModel

@{
    ViewData["Title"] = "Add Role";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Applications", Url.Action("Index","Applications")), ("Application", Url.Action("Details","Applications", new { id = Model.ApplicationId })), ("Add Role", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />

    <form asp-action="AddRole" asp-route-id="@Model.ApplicationId" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ApplicationId" />
        <input type="hidden" asp-for="ApplicationName" />

        <div>
            <label asp-for="Name" class="block text-sm/6 font-medium text-gray-900">Role Name</label>
            <div class="mt-2">
                <input asp-for="Name" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>
        <div>
            <label asp-for="Description" class="block text-sm/6 font-medium text-gray-900">Description</label>
            <div class="mt-2">
                <input asp-for="Description" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>
        <div class="flex items-start gap-x-3">
            <input asp-for="IsDefault" type="checkbox" class="mt-1 h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
            <div>
                <label asp-for="IsDefault" class="text-sm/6 font-medium text-gray-900">Default Role</label>
                <p class="text-xs text-gray-500">Automatically assigned to new members who have no role yet for this application.</p>
            </div>
        </div>
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="Details" asp-route-id="@Model.ApplicationId" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>
