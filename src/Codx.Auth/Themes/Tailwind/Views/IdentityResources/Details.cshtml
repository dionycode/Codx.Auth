@model IdentityResourceDetailsViewModel

@{
    ViewData["Title"] = "Identity Resource Details";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Identity Resources", Url.Action("Index","IdentityResources")), (Model.Name, (string?)null) } })' />
<partial name="_PageHeading" />

<div class="mb-4 flex gap-x-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-700 shadow-xs ring-1 ring-inset ring-red-300 hover:bg-red-50">Delete</a>
</div>

<div x-data="{ tab: 'details' }">
    <div class="border-b border-gray-200 mb-6">
        <nav class="-mb-px flex space-x-6">
            <button @@click="tab='details'" :class="tab==='details' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Details</button>
            <button @@click="tab='claims'; loadClaims()" :class="tab==='claims' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Claims</button>
            <button @@click="tab='properties'; loadProperties()" :class="tab==='properties' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'" class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium">Properties</button>
        </nav>
    </div>

    <div x-show="tab==='details'">
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-6">
            <dl class="divide-y divide-gray-100">
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Name</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Display Name</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.DisplayName</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Enabled</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Enabled</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Description</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Description</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Required</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Required</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Emphasize</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Emphasize</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Show In Discovery Document</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.ShowInDiscoveryDocument</dd></div>
                <div class="py-3 sm:grid sm:grid-cols-3 sm:gap-4"><dt class="text-sm font-medium text-gray-900">Non-Editable</dt><dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.NonEditable</dd></div>
            </dl>
        </div>
    </div>

    <div x-show="tab==='claims'">
        <div class="mb-3">
            <a asp-action="Add" asp-controller="IdentityResourceClaims" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add Claim</a>
        </div>
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Type</th><th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500">Actions</th></tr></thead>
                <tbody id="tbody-claims" class="divide-y divide-gray-100 bg-white"></tbody>
            </table>
        </div>
    </div>

    <div x-show="tab==='properties'">
        <div class="mb-3">
            <a asp-action="Add" asp-controller="IdentityResourceProperties" asp-route-id="@Model.Id" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add Property</a>
        </div>
        <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Key</th><th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Value</th><th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500">Actions</th></tr></thead>
                <tbody id="tbody-properties" class="divide-y divide-gray-100 bg-white"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
var modelId = @Model.Id;
var claimsLoaded = false;
var propertiesLoaded = false;

function makeActions(controller, id) {
    var frag = document.createDocumentFragment();
    var links = [
        { href: '/' + controller + '/Details/' + id, label: 'Details' },
        { href: '/' + controller + '/Edit/' + id, label: 'Edit' },
        { href: '/' + controller + '/Delete/' + id, label: 'Delete', red: true }
    ];
    links.forEach(function(l) {
        var a = document.createElement('a');
        a.href = l.href;
        a.className = l.red
            ? 'ml-2 text-sm font-medium text-red-600 hover:text-red-500'
            : 'text-sm font-medium text-indigo-600 hover:text-indigo-500';
        a.textContent = l.label;
        frag.appendChild(a);
    });
    return frag;
}

function fillTable(tbodyId, url, params, cols) {
    fetch(url + '?' + new URLSearchParams(Object.assign({ offset: 0, limit: 200 }, params)))
        .then(function(r) { return r.json(); })
        .then(function(res) {
            var tbody = document.getElementById(tbodyId);
            tbody.innerHTML = '';
            var rows = res.rows || [];
            if (!rows.length) {
                var tr = document.createElement('tr');
                var td = document.createElement('td');
                td.colSpan = cols.length + 1;
                td.className = 'px-6 py-4 text-sm text-gray-500 text-center';
                td.textContent = 'No records found.';
                tr.appendChild(td); tbody.appendChild(tr);
                return;
            }
            rows.forEach(function(row) {
                var tr = document.createElement('tr'); tr.className = 'hover:bg-gray-50';
                cols.forEach(function(col) {
                    var td = document.createElement('td'); td.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900'; td.textContent = row[col] || '';
                    tr.appendChild(td);
                });
                var tdAct = document.createElement('td'); tdAct.className = 'whitespace-nowrap px-6 py-4 text-right';
                tdAct.appendChild(makeActions(params.controller, row.id));
                tr.appendChild(tdAct); tbody.appendChild(tr);
            });
        });
}

function loadClaims() {
    if (claimsLoaded) return; claimsLoaded = true;
    fillTable('tbody-claims', '@Url.Action("GetIdentityResourceClaimsTableData","IdentityResourceClaims")',
        { identityresourceid: modelId, controller: 'IdentityResourceClaims' }, ['type']);
}

function loadProperties() {
    if (propertiesLoaded) return; propertiesLoaded = true;
    fillTable('tbody-properties', '@Url.Action("GetIdentityResourcePropertiesTableData","IdentityResourceProperties")',
        { identityresourceid: modelId, controller: 'IdentityResourceProperties' }, ['key', 'value']);
}
</script>
}
