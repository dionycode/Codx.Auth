@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_BlankLayout";
}

<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-gray-900">Sign in to your account</h2>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8">

        @if (Model.EnableLocalLogin)
        {
            @* UnverifiedEmail alert *@
            @if (TempData["UnverifiedEmail"] != null)
            {
                <div x-data="{ show: true }" x-show="show" class="rounded-md bg-yellow-50 p-4 mb-6 ring-1 ring-inset ring-yellow-600/10">
                    <div class="flex">
                        <div class="shrink-0">
                            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3 flex-1">
                            <h3 class="text-sm font-medium text-yellow-800">Email Not Verified</h3>
                            <div class="mt-2 text-sm text-yellow-700">
                                <p>Your email address hasn't been verified yet. Please check your inbox for the verification link.</p>
                                <p class="mt-1"><strong>Didn't receive the email?</strong></p>
                                <form asp-action="ResendEmailVerification" method="post" class="mt-2">
                                    <input type="hidden" name="email" value="@TempData.Peek("UnverifiedEmail")" />
                                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                    <button type="submit" class="rounded-md bg-yellow-100 px-3 py-1.5 text-sm font-medium text-yellow-800 hover:bg-yellow-200">
                                        Resend Verification Email
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" @@click="show = false" class="-mx-1.5 -my-1.5 rounded-md bg-yellow-50 p-1.5 text-yellow-500 hover:bg-yellow-100">
                                <span class="sr-only">Dismiss</span>
                                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <form asp-route="Login" class="space-y-5">
                <input type="hidden" asp-for="ReturnUrl" />

                <partial name="_ValidationSummary" />

                <div>
                    <label asp-for="Username" class="block text-sm/6 font-medium text-gray-900">Username</label>
                    <div class="mt-2">
                        <input asp-for="Username" autofocus
                               class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    </div>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm/6 font-medium text-gray-900">Password</label>
                    <div class="mt-2">
                        <input type="password" asp-for="Password" autocomplete="off"
                               class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    </div>
                </div>

                @if (Model.AllowRememberLogin)
                {
                    <div class="flex items-center">
                        <input asp-for="RememberLogin" type="checkbox"
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
                        <label asp-for="RememberLogin" class="ml-3 block text-sm/6 text-gray-900">Remember My Login</label>
                    </div>
                }

                <div class="flex gap-x-3">
                    <button class="flex-1 rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
                            name="button" value="login">Login</button>
                </div>
            </form>

            <div class="mt-4">
                <a asp-controller="Account" asp-action="Register" class="text-sm text-indigo-600 hover:text-indigo-500">Don't have an account? Register</a>
            </div>

            @if (Model.VisibleExternalProviders.Any())
            {
                <hr class="my-6 border-gray-200" />
                <div class="space-y-2">
                    @foreach (var provider in Model.VisibleExternalProviders)
                    {
                        <a class="flex w-full items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
                           asp-controller="External"
                           asp-action="Challenge"
                           asp-route-scheme="@provider.AuthenticationScheme"
                           asp-route-returnUrl="@Model.ReturnUrl">
                            Sign In with @provider.DisplayName
                        </a>
                    }
                </div>
            }
        }

        @if (!Model.EnableLocalLogin && !Model.VisibleExternalProviders.Any())
        {
            <div class="rounded-md bg-yellow-50 p-4 ring-1 ring-inset ring-yellow-600/10">
                <p class="text-sm text-yellow-800"><strong>Invalid login request</strong> — there are no login schemes configured for this request.</p>
            </div>
        }

    </div>
</div>
