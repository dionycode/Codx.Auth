@model Codx.Auth.ViewModels.Account.EmailVerificationViewModel
@{
    ViewData["Title"] = "Email Verification Sent";
    Layout = "_BlankLayout";
}

<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 text-center">
        <svg class="mx-auto h-12 w-12 @(Model.IsError ? "text-red-400" : "text-indigo-500")" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">@(Model.IsError ? "Error" : "Email Sent!")</h2>
        <p class="mt-2 text-sm @(Model.IsError ? "text-red-600" : "text-gray-600")">@Model.Message</p>
        @if (!Model.IsError && !string.IsNullOrWhiteSpace(Model.Email))
        {
            <p class="mt-2 text-sm font-semibold text-indigo-600">@Model.Email</p>
            <p class="mt-2 text-sm text-gray-500">Check your inbox for the verification link.</p>
        }
        <div class="mt-6">
            <a asp-controller="Account" asp-action="Login" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">← Back to Sign In</a>
        </div>
    </div>
</div>
