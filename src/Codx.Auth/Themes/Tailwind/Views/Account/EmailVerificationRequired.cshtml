@model Codx.Auth.ViewModels.Account.EmailVerificationViewModel
@{
    ViewData["Title"] = "Email Verification Required";
    Layout = "_BlankLayout";
}

<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 text-center">
        <svg class="mx-auto h-12 w-12 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Email Verification Required</h2>
        <p class="mt-2 text-sm text-gray-600">@Model.Message</p>
        @if (!string.IsNullOrWhiteSpace(Model.Email))
        {
            <p class="mt-2 text-sm font-semibold text-indigo-600">@Model.Email</p>
        }
        <div class="mt-6">
            <a asp-controller="Account" asp-action="Login" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">← Back to Sign In</a>
        </div>
    </div>
</div>
