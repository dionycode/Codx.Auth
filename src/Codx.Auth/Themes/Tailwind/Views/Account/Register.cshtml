@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_BlankLayout";
}

<div class="sm:mx-auto sm:w-full sm:max-w-lg">
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-gray-900">Create your account</h2>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-lg">
    <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8">

        <partial name="_ValidationSummary" />

        <form asp-action="Register" method="post" class="space-y-5">
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="IsInviteMode" />

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                    <label asp-for="FirstName" class="block text-sm/6 font-medium text-gray-900">First Name</label>
                    <div class="mt-3">
                        <input asp-for="FirstName" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    </div>
                    <span asp-validation-for="FirstName" class="text-sm text-red-600"></span>
                </div>
                <!-- <div>
                    <label asp-for="MiddleName" class="block text-sm/6 font-medium text-gray-900">Middle Name</label>
                    <div class="mt-2">
                        <input asp-for="MiddleName" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    </div>
                    <span asp-validation-for="MiddleName" class="text-sm text-red-600"></span>
                </div> -->
                <div>
                    <label asp-for="LastName" class="block text-sm/6 font-medium text-gray-900">Last Name</label>
                    <div class="mt-3">
                        <input asp-for="LastName" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    </div>
                    <span asp-validation-for="LastName" class="text-sm text-red-600"></span>
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm/6 font-medium text-gray-900">Email</label>
                <div class="mt-2">
                    @if (Model.IsInviteMode)
                    {
                        <input asp-for="Email" readonly class="block w-full rounded-md bg-gray-50 px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 sm:text-sm/6" />
                        <p class="mt-1 text-sm/6 text-gray-600">Your email address is pre-filled from your invitation and cannot be changed.</p>
                    }
                    else
                    {
                        <input asp-for="Email" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                    }
                </div>
                <span asp-validation-for="Email" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm/6 font-medium text-gray-900">Password</label>
                <div class="mt-2">
                    <input type="password" asp-for="Password" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                </div>
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm/6 font-medium text-gray-900">Confirm Password</label>
                <div class="mt-2">
                    <input type="password" asp-for="ConfirmPassword" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600"></span>
            </div>

            <div>
                <button type="submit" class="w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                    Register
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
