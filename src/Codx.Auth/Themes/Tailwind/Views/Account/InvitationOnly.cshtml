@{
    ViewData["Title"] = "Invitation Required";
    Layout = "_Layout";
}

<div class="max-w-md mx-auto text-center py-12">
    <svg class="mx-auto h-12 w-12 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
    </svg>
    <h2 class="mt-4 text-xl font-semibold text-gray-900">Registration by Invitation Only</h2>
    <p class="mt-2 text-sm text-gray-600">This application does not allow public self-registration. Please contact your administrator to request an invitation.</p>
    <div class="mt-6">
        <a asp-action="Login" asp-controller="Account" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Back to Sign In</a>
    </div>
</div>
