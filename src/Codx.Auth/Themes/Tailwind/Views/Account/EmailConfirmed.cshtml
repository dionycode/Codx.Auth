@model Codx.Auth.ViewModels.Account.EmailConfirmedViewModel
@{
    ViewData["Title"] = Model.Success ? "Email Confirmed" : "Email Confirmation Failed";
    Layout = "_BlankLayout";
}

<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 text-center">
        @if (Model.Success)
        {
            <svg class="mx-auto h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h2 class="mt-4 text-xl font-semibold text-gray-900">Email Confirmed!</h2>
            <p class="mt-2 text-sm text-gray-600">@Model.Message</p>
            <div class="mt-6">
                <a asp-controller="Account" asp-action="Login" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Sign In</a>
            </div>
        }
        else
        {
            <svg class="mx-auto h-12 w-12 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h2 class="mt-4 text-xl font-semibold text-gray-900">Confirmation Failed</h2>
            <p class="mt-2 text-sm text-gray-600">@Model.Message</p>
            <div class="mt-6">
                <a asp-controller="Account" asp-action="Login" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">← Back to Sign In</a>
            </div>
        }
    </div>
</div>
