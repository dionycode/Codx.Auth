@{
    ViewData["Title"] = "Clients";
}

<partial name="_PageHeading" />

<div class="sm:flex sm:items-center mb-4">
    <div class="sm:flex-auto"></div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <a asp-action="Add" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">Add Client</a>
    </div>
</div>

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200" id="clientTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client ID</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client Name</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white" id="clientTableBody">
                <tr><td colspan="3" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
            </tbody>
        </table>
    </div>
    <div class="flex items-center justify-between border-t border-gray-200 bg-white px-4 py-3 sm:px-6" id="clientPagination"></div>
</div>

@section Scripts {
<script>
(function () {
    var url = '@Url.Action("GetClientsTableData", "Clients")';
    var currentOffset = 0;
    var pageSize = 10;

    function loadPage(offset) {
        fetch(url + '?offset=' + offset + '&limit=' + pageSize)
            .then(function (r) { return r.json(); })
            .then(function (res) {
                var tbody = document.getElementById('clientTableBody');
                tbody.innerHTML = '';
                if (!res.rows || res.rows.length === 0) {
                    var empty = document.createElement('tr');
                    var td = document.createElement('td');
                    td.colSpan = 3;
                    td.className = 'px-6 py-4 text-sm text-gray-500';
                    td.textContent = 'No clients found.';
                    empty.appendChild(td);
                    tbody.appendChild(empty);
                    return;
                }
                res.rows.forEach(function (row) {
                    var tr = document.createElement('tr');
                    tr.className = 'hover:bg-gray-50';

                    var tdClientId = document.createElement('td');
                    tdClientId.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900';
                    tdClientId.textContent = row.clientId;

                    var tdName = document.createElement('td');
                    tdName.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-500';
                    tdName.textContent = row.clientName;

                    var tdActions = document.createElement('td');
                    tdActions.className = 'whitespace-nowrap px-6 py-4 text-right text-sm font-medium';

                    var aDetails = document.createElement('a');
                    aDetails.href = '/Clients/Details/' + row.id;
                    aDetails.className = 'text-indigo-600 hover:text-indigo-900 mr-3';
                    aDetails.textContent = 'Details';

                    var aEdit = document.createElement('a');
                    aEdit.href = '/Clients/Edit/' + row.id;
                    aEdit.className = 'text-indigo-600 hover:text-indigo-900 mr-3';
                    aEdit.textContent = 'Edit';

                    var aDelete = document.createElement('a');
                    aDelete.href = '/Clients/Delete/' + row.id;
                    aDelete.className = 'text-red-600 hover:text-red-900';
                    aDelete.textContent = 'Delete';

                    tdActions.appendChild(aDetails);
                    tdActions.appendChild(aEdit);
                    tdActions.appendChild(aDelete);

                    tr.appendChild(tdClientId);
                    tr.appendChild(tdName);
                    tr.appendChild(tdActions);
                    tbody.appendChild(tr);
                });

                var pag = document.getElementById('clientPagination');
                pag.innerHTML = '';
                var total = res.total || 0;
                var start = offset + 1;
                var end = Math.min(offset + pageSize, total);
                var info = document.createElement('p');
                info.className = 'text-sm text-gray-700';
                info.textContent = 'Showing ' + start + ' to ' + end + ' of ' + total + ' results';
                pag.appendChild(info);

                var btns = document.createElement('div');
                btns.className = 'flex gap-x-2';

                var prev = document.createElement('button');
                prev.type = 'button';
                prev.textContent = 'Previous';
                prev.disabled = offset === 0;
                prev.className = 'rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50 disabled:opacity-50';
                prev.addEventListener('click', function () { loadPage(offset - pageSize); });

                var next = document.createElement('button');
                next.type = 'button';
                next.textContent = 'Next';
                next.disabled = end >= total;
                next.className = 'rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50 disabled:opacity-50';
                next.addEventListener('click', function () { loadPage(offset + pageSize); });

                btns.appendChild(prev);
                btns.appendChild(next);
                pag.appendChild(btns);
            });
    }

    loadPage(0);
}());
</script>
}
