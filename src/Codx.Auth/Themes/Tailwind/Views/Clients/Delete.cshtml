@model ClientEditViewModel

@{
    ViewData["Title"] = "Delete Client";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Clients", Url.Action("Index","Clients")), ("Client", Url.Action("Details","Clients", new { id = Model.Id })), ("Delete Client", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <div class="rounded-md bg-red-50 p-4 ring-1 ring-inset ring-red-600/10 mb-6">
        <p class="text-sm font-medium text-red-800">Are you sure you want to delete this client? This action cannot be undone.</p>
    </div>

    <dl class="divide-y divide-gray-100 mb-6">
        <div class="px-4 py-3 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
            <dt class="text-sm font-medium text-gray-900">Client ID</dt>
            <dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.ClientId</dd>
        </div>
        <div class="px-4 py-3 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
            <dt class="text-sm font-medium text-gray-900">Client Name</dt>
            <dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.ClientName</dd>
        </div>
        <div class="px-4 py-3 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
            <dt class="text-sm font-medium text-gray-900">Description</dt>
            <dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0">@Model.Description</dd>
        </div>
    </dl>

    <form asp-action="Delete" class="flex gap-x-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
    </form>
</div>
