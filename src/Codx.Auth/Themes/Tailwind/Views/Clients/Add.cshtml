@model ClientAddViewModel

@{
    ViewData["Title"] = "Add Client";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Clients", Url.Action("Index","Clients")), ("Add Client", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />

    <form asp-action="Add" class="space-y-5">

        <div>
            <label asp-for="ClientId" class="block text-sm/6 font-medium text-gray-900">Client ID</label>
            <div class="mt-2">
                <input asp-for="ClientId" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="ClientName" class="block text-sm/6 font-medium text-gray-900">Client Name</label>
            <div class="mt-2">
                <input asp-for="ClientName" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm/6 font-medium text-gray-900">Description</label>
            <div class="mt-2">
                <input asp-for="Description" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="ApplicationId" class="block text-sm/6 font-medium text-gray-900">Application (optional)</label>
            <div class="mt-2">
                <select asp-for="ApplicationId" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
                    <option value="">— None —</option>
                    @if (ViewBag.Applications != null)
                    {
                        foreach (var app in (System.Collections.IEnumerable)ViewBag.Applications)
                        {
                            var appItem = (dynamic)app;
                            <option value="@appItem.Id">@appItem.DisplayName (@appItem.Id)</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Save</button>
            <a asp-action="Index" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>

    </form>
</div>
