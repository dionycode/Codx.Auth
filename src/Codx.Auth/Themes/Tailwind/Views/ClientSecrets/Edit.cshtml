@model ClientSecretEditViewModel

@{
    ViewData["Title"] = "Edit Client Secret";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Clients", Url.Action("Index","Clients")), ("Client", Url.Action("Details","Clients", new { id = Model.ClientId })), ("Edit Secret", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />
    <form asp-action="Edit" class="space-y-5">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ClientId" />
        <input type="hidden" asp-for="Value" />
        <div><label asp-for="Type" class="block text-sm/6 font-medium text-gray-900">Type</label><div class="mt-2"><input asp-for="Type" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div><label asp-for="NewSecret" class="block text-sm/6 font-medium text-gray-900">New Secret</label><div class="mt-2"><input asp-for="NewSecret" type="password" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div><label asp-for="Description" class="block text-sm/6 font-medium text-gray-900">Description</label><div class="mt-2"><input asp-for="Description" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div><label asp-for="Expiration" class="block text-sm/6 font-medium text-gray-900">Expiration</label><div class="mt-2"><input asp-for="Expiration" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" /></div></div>
        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save</button>
            <a asp-action="Details" asp-controller="Clients" asp-route-id="@Model.ClientId" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>
    </form>
</div>
