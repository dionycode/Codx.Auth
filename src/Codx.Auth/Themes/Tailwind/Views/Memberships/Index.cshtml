@using Codx.Auth.Data.Entities.Enterprise
@model List<UserMembership>

@{
    ViewData["Title"] = "Memberships";
    Guid tenantId = ViewBag.TenantId;
    Guid? companyId = ViewBag.CompanyId;
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

<nav aria-label="Breadcrumb" class="mb-4">
    <ol class="flex items-center gap-x-2 text-sm text-gray-500">
        <li><a href="@Url.Action("Index","Home")" class="hover:text-gray-700">Home</a></li>
        <li><span class="mx-1">/</span></li>
        @if (User.IsInRole("PlatformAdministrator"))
        {
            <li><a href="@Url.Action("Index","Tenants")" class="hover:text-gray-700">Tenants</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a asp-controller="Tenants" asp-action="Details" asp-route-id="@tenantId" class="hover:text-gray-700">Tenant</a></li>
            @if (companyId.HasValue)
            {
                <li><span class="mx-1">/</span></li>
                <li><a asp-controller="Companies" asp-action="Details" asp-route-id="@companyId" class="hover:text-gray-700">Company</a></li>
            }
        }
        else
        {
            <li><a href="@Url.Action("Index","MyProfile")" class="hover:text-gray-700">My Profile</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a asp-controller="MyProfile" asp-action="ManageTenant" asp-route-id="@tenantId" class="hover:text-gray-700">Tenant</a></li>
            @if (companyId.HasValue)
            {
                <li><span class="mx-1">/</span></li>
                <li><a asp-controller="MyProfile" asp-action="ManageTenantCompanyDetails" asp-route-id="@companyId" class="hover:text-gray-700">Company</a></li>
            }
        }
        <li><span class="mx-1">/</span></li>
        <li class="text-gray-900 font-medium" aria-current="page">Memberships</li>
    </ol>
</nav>

<div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-gray-900">Memberships</h1>
    <a asp-controller="Memberships" asp-action="Create" asp-route-tenantId="@tenantId" asp-route-companyId="@companyId"
       class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Add Membership</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="rounded-md bg-green-50 p-4 ring-1 ring-inset ring-green-600/20 mb-4">
        <p class="text-sm text-green-800">@TempData["Success"]</p>
    </div>
}

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">User</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Roles</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Joined</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
            @foreach (var m in Model)
            {
                <tr class="hover:bg-gray-50">
                    <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900">@(m.User?.UserName ?? m.UserId.ToString())</td>
                    <td class="px-6 py-4 text-sm text-gray-900">@string.Join(", ", m.MembershipRoles?.Select(r => r.RoleDefinition?.DisplayName ?? r.RoleId.ToString()) ?? Enumerable.Empty<string>())</td>
                    <td class="whitespace-nowrap px-6 py-4 text-sm">
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @(m.Status == "Active" ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800")">@m.Status</span>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900">@m.JoinedAt.ToLocalTime().ToString("g")</td>
                    <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                        <a asp-action="Details" asp-route-id="@m.Id" class="text-indigo-600 hover:text-indigo-500 font-medium mr-3">Details</a>
                        @if (m.Status == "Active")
                        {
                            <form asp-action="Deactivate" asp-route-id="@m.Id" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tenantId" value="@tenantId" />
                                <input type="hidden" name="companyId" value="@companyId" />
                                <button type="submit" class="text-yellow-600 hover:text-yellow-500 font-medium">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No memberships found.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav class="mt-4 flex gap-x-1">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a asp-action="Index" asp-route-tenantId="@tenantId" asp-route-companyId="@companyId" asp-route-page="@i"
               class="@(i == page ? "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white" : "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50")">@i</a>
        }
    </nav>
}
