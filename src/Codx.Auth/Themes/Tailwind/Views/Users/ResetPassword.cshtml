@model UserResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<partial name="_Breadcrumb" view-data='@(new ViewDataDictionary(ViewData) { ["BreadcrumbItems"] = new[] { ("Home", Url.Action("Index","Home")), ("Users", Url.Action("Index","Users")), (Model.UserName, Url.Action("Details","Users", new { id = Model.Id })), ("Reset Password", (string?)null) } })' />
<partial name="_PageHeading" />

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200 px-6 py-8 max-w-2xl">
    <partial name="_ValidationSummary" />

    <form asp-action="ResetPassword" class="space-y-5">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="UserName" class="block text-sm/6 font-medium text-gray-900">Username</label>
            <div class="mt-2">
                <input asp-for="UserName" readonly class="block w-full rounded-md bg-gray-50 px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="NewPassword" class="block text-sm/6 font-medium text-gray-900">New Password</label>
            <div class="mt-2">
                <input type="password" asp-for="NewPassword" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="block text-sm/6 font-medium text-gray-900">Confirm Password</label>
            <div class="mt-2">
                <input type="password" asp-for="ConfirmPassword" class="block w-full rounded-md bg-white px-3 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
            </div>
        </div>

        <div class="flex gap-x-3">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Reset Password</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Cancel</a>
        </div>

    </form>
</div>
