@{
    ViewData["Title"] = "API Scopes";
}

<partial name="_PageHeading" />

<div class="sm:flex sm:items-center mb-4">
    <div class="sm:flex-auto"></div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <a asp-action="Add" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">Add API Scope</a>
    </div>
</div>

<div class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-inset ring-gray-200">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Display Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Enabled</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white" id="tableBody">
                <tr><td colspan="4" class="px-6 py-4 text-sm text-gray-500">Loading&hellip;</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    fetch('@Url.Action("GetApiScopesTableData","ApiScopes")?offset=0&limit=200')
        .then(function (r) { return r.json(); })
        .then(function (res) {
            var tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            var rows = res.rows || [];
            if (!rows.length) {
                var tr = document.createElement('tr');
                var td = document.createElement('td'); td.colSpan = 4; td.className = 'px-6 py-4 text-sm text-gray-500'; td.textContent = 'No API scopes found.';
                tr.appendChild(td); tbody.appendChild(tr); return;
            }
            rows.forEach(function (row) {
                var tr = document.createElement('tr'); tr.className = 'hover:bg-gray-50';
                var td1 = document.createElement('td'); td1.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-900'; td1.textContent = row.name;
                var td2 = document.createElement('td'); td2.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-500'; td2.textContent = row.displayName || '';
                var td3 = document.createElement('td'); td3.className = 'whitespace-nowrap px-6 py-4 text-sm text-gray-500'; td3.textContent = row.enabled ? 'Yes' : 'No';
                var tdAct = document.createElement('td'); tdAct.className = 'whitespace-nowrap px-6 py-4 text-right text-sm font-medium';
                ['Details','Edit','Delete'].forEach(function(action) {
                    var a = document.createElement('a');
                    a.href = '/ApiScopes/' + action + '/' + row.id;
                    a.className = action === 'Delete' ? 'text-red-600 hover:text-red-900 ml-3' : 'text-indigo-600 hover:text-indigo-900 ml-3';
                    a.textContent = action;
                    tdAct.appendChild(a);
                });
                tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3); tr.appendChild(tdAct);
                tbody.appendChild(tr);
            });
        });
}());
</script>
}
